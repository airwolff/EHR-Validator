# Secrets — never commit
.env

# Database (regenerated by load_results.py)
ehr_triage.db

# Credit ledger — machine state (real money spent on THIS machine), not source.
# Committing it would merge-conflict and, worse, let a stale checkout resurrect an old
# spend count. Delete it only if you accept losing the spend record.
# Both names: the default path (LYZR_LEDGER_PATH) and the bare name, so a ledger written
# anywhere in the tree is ignored rather than silently committed.
.lyzr_ledger.json
ledger.json

# Generated data (regenerated by generate_payloads.py).
# Leading slash anchors this to the repo root — an unanchored "payloads/" also
# matches tests/fixtures/payloads/, which is tracked test data.
/payloads/

# Python
__pycache__/
*.pyc
.venv/
venv/

.DS_Store
